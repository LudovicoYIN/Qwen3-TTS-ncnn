 namespace ncnn {
 
+static int sdpa_attn_mask_dims_for_shader(const VkMat& attn_mask_blob)
+{
+    if (attn_mask_blob.empty())
+        return 0;
+
+    // CPU SDPA broadcasts c==1 mask to all heads. The shader uses dims==3 to
+    // select per-head mask via gz * mask_cstep, so c==1 must not be reported as 3.
+    if (attn_mask_blob.dims == 3 && attn_mask_blob.c <= 1)
+        return 2;
+
+    return attn_mask_blob.dims;
+}
+
